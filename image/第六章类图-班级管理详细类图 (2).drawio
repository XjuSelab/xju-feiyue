        <mxCell id="title" value="班级管理模块详细类图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontStyle=1;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="640" y="25" width="520" height="44" as="geometry" />
        </mxCell>
        <mxCell id="note" value="范围：/classes/me 班级空间、/admin/classes 后台班级维护、/groups 小组空间。类中列出核心字段和主要业务操作，关系线标注 FK、组合关系、状态枚举和权限边界。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fontSize=13;fillColor=#f8fafc;strokeColor=#cbd5e1;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="330" y="82" width="1140" height="54" as="geometry" />
        </mxCell>

        <mxCell id="user" value="&lt;&lt;entity&gt;&gt;&#xa;User&#xa;------------------------------&#xa;+ sid: String(11) PK&#xa;+ name: String&#xa;+ nickname: String&#xa;+ avatarThumb: String?&#xa;+ role: user | admin | superadmin&#xa;+ classId: int? FK&#xa;+ isClassCommittee: bool&#xa;+ committeeTitle: String?&#xa;------------------------------&#xa;+ classFullName(): String?&#xa;+ classShortName(): String?&#xa;+ setUserClass(classId?)&#xa;+ setUserCommittee(flag,title?)&#xa;+ setMemberCommittee(sid,flag,title?)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="290" height="300" as="geometry" />
        </mxCell>
        <mxCell id="student-class" value="&lt;&lt;entity&gt;&gt;&#xa;StudentClass&#xa;------------------------------&#xa;+ id: int PK&#xa;+ fullName: String(120) unique&#xa;+ shortName: String(64) unique&#xa;+ createdAt: DateTime&#xa;------------------------------&#xa;+ listClasses()&#xa;+ createClass(fullName, shortName)&#xa;+ updateClass(id, names)&#xa;+ deleteClass(id)&#xa;+ countClassMembers()" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="430" y="170" width="300" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rollcall-session" value="&lt;&lt;entity&gt;&gt;&#xa;RollCallSession&#xa;------------------------------&#xa;+ id: String PK&#xa;+ classId: int FK&#xa;+ title: String?&#xa;+ createdBySid: String FK&#xa;+ createdAt: DateTime&#xa;+ closedAt: DateTime?&#xa;------------------------------&#xa;+ createRollcall(title?)&#xa;+ listRollcalls(limit,offset)&#xa;+ updateRollcall(title?,closed?)&#xa;+ deleteRollcall()&#xa;+ rollcallDetail()" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="820" y="170" width="310" height="260" as="geometry" />
        </mxCell>
        <mxCell id="rollcall-record" value="&lt;&lt;entity&gt;&gt;&#xa;RollCallRecord&#xa;------------------------------&#xa;+ sessionId: String PK, FK&#xa;+ sid: String PK, FK&#xa;+ present: bool&#xa;+ checkedAt: DateTime?&#xa;+ checkedBySid: String?&#xa;------------------------------&#xa;+ upsertRecord(sid,present)&#xa;+ setPresent(present)&#xa;+ auditCheckedBy(actor)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="1215" y="170" width="295" height="220" as="geometry" />
        </mxCell>
        <mxCell id="enums" value="&lt;&lt;enum&gt;&gt;&#xa;状态与角色枚举&#xa;------------------------------&#xa;UserRole = user | admin | superadmin&#xa;GroupRole = leader | member&#xa;JoinRequestStatus = pending | approved | rejected&#xa;TaskStatus = todo | doing | done" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#fefce8;strokeColor=#ca8a04;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="1560" y="170" width="210" height="190" as="geometry" />
        </mxCell>

        <mxCell id="group-member" value="&lt;&lt;association&gt;&gt;&#xa;GroupMember&#xa;------------------------------&#xa;+ groupId: String PK, FK&#xa;+ sid: String PK, FK&#xa;+ role: leader | member&#xa;+ joinedAt: DateTime&#xa;------------------------------&#xa;+ membershipOf(gid,sid)&#xa;+ transferLeader(targetSid)&#xa;+ removeMember(sid)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="40" y="535" width="290" height="220" as="geometry" />
        </mxCell>
        <mxCell id="group" value="&lt;&lt;entity&gt;&gt;&#xa;Group&#xa;------------------------------&#xa;+ id: String PK&#xa;+ classId: int FK&#xa;+ name: String&#xa;+ logo: String?&#xa;+ logoThumb: String?&#xa;+ intro: Text&#xa;+ leaderSid: String FK&#xa;+ deleted: bool&#xa;+ createdAt: DateTime&#xa;+ updatedAt: DateTime&#xa;------------------------------&#xa;+ createGroup(name,intro)&#xa;+ updateGroup(name?,intro?)&#xa;+ uploadLogo(file)&#xa;+ softDeleteGroup()&#xa;+ groupDetailOut(viewer)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
