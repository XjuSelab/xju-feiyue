        <mxCell id="group-task" value="&lt;&lt;entity&gt;&gt;&#xa;GroupTask&#xa;------------------------------&#xa;+ id: String PK&#xa;+ groupId: String FK&#xa;+ title: String&#xa;+ description: Text&#xa;+ startDate: Date&#xa;+ endDate: Date&#xa;+ status: todo | doing | done&#xa;+ progress: int 0-100&#xa;+ createdBySid: String FK&#xa;+ createdAt: DateTime&#xa;+ updatedAt: DateTime&#xa;------------------------------&#xa;+ createTask(body)&#xa;+ updateTask(patch)&#xa;+ deleteTask()&#xa;+ validateTaskDates(start,end)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
