        <mxCell id="group-file" value="&lt;&lt;entity&gt;&gt;&#xa;GroupFile&#xa;------------------------------&#xa;+ id: String PK&#xa;+ groupId: String FK&#xa;+ name: String&#xa;+ ext: String?&#xa;+ mime: String?&#xa;+ sizeBytes: int?&#xa;+ url: String?&#xa;+ storagePath: String?&#xa;+ uploadedBySid: String FK&#xa;+ deleted: bool&#xa;+ createdAt: DateTime&#xa;------------------------------&#xa;+ uploadFiles(files)&#xa;+ listGroupFiles()&#xa;+ downloadFile()&#xa;+ deleteFile()" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="1215" y="480" width="295" height="300" as="geometry" />
        </mxCell>
        <mxCell id="rules" value="&lt;&lt;constraint&gt;&gt;&#xa;核心业务规则&#xa;------------------------------&#xa;1. 普通用户 URL 不暴露 classId，均从 JWT user.classId 推导。&#xa;2. 读班级需本班成员；点名写入需班委或 admin。&#xa;3. 小组管理需组长、班委或 admin。&#xa;4. 同班每人最多一个 live group。&#xa;5. approve 入组会创建 GroupMember 并自动拒绝同班其它 pending。" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="1560" y="450" width="210" height="270" as="geometry" />
        </mxCell>

        <mxCell id="classes-service" value="&lt;&lt;service&gt;&gt;&#xa;ClassesService&#xa;------------------------------&#xa;+ ensureInClass(user): int&#xa;+ isCommitteeOf(user,classId): bool&#xa;+ ensureCommittee(user,classId)&#xa;+ isBanzhangOf(user,classId): bool&#xa;+ listClassMembers(classId)&#xa;+ createRollcall(classId,actor,title?)&#xa;+ rollcallSummaries(classId,limit,offset)&#xa;+ rollcallDetail(session)&#xa;+ upsertRecord(session,sid,present,actor)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#fff7ed;strokeColor=#f97316;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="340" height="245" as="geometry" />
        </mxCell>
        <mxCell id="groups-service" value="&lt;&lt;service&gt;&gt;&#xa;GroupsService&#xa;------------------------------&#xa;+ getGroupOr404(gid)&#xa;+ ensureClassMember(group,user)&#xa;+ ensureGroupMember(group,user)&#xa;+ ensureGroupManager(group,user)&#xa;+ createGroup(classId,creator,name,intro)&#xa;+ createJoinRequest(group,user,message?)&#xa;+ approveRequest(group,request,actor)&#xa;+ rejectRequest(request,actor)&#xa;+ validateAssignees(group,sids)&#xa;+ setTaskAssignees(taskId,sids)&#xa;+ tasksOut(gid)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=12;fillColor=#fff7ed;strokeColor=#f97316;fontColor=#17212b;" vertex="1" parent="1">
          <mxGeometry x="430" y="860" width="330" height="285" as="geometry" />
