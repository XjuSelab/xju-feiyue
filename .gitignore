# Upstream xju-course-wiki source mirror — entirely raw / regenerable via
# `python scripts/xju_pull.py`. Not tracked.
scripts/xju_wiki_raw/

# Playwright MCP transient cache (screenshots + console logs).
.playwright-mcp/
frontend/playwright/screenshots/

# Local screenshots from manual UI iteration (per-session, regenerable).
*.png

# Python bytecode cache.
__pycache__/

# Backend file-uploads (avatars etc.) — not tracked; deploy syncs them
# via the HF state-sync (or remount the volume in prod).
backend/uploads/

# Schools advisor reference data — large (~20MB sqlite), regenerable by
# supervisor-claw, synced out-of-band to the xju-feiyue-data HF dataset
# (`make schools-push` / `make schools-pull`; see scripts/sync/schools.py).
# Not tracked in git — the git push timed out on the 23MB blob.
backend/data/schools/

# CCF conferences reference data — read-only service sqlite, seeded by
# scripts/seed_conferences.py and (R3) maintained by the conf crawler. Synced
# out-of-band to the xju-feiyue-data HF dataset under the conferences/ namespace
# (`make conf-push` / `make conf-pull`). Regenerable, so kept out of git.
backend/data/conferences/
