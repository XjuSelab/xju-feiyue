<mxfile host="app.diagrams.net" type="device">
  <diagram id="fig2" name="图4-2 顶层数据流图">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!--
          布局网格（x,y,w,h）：
          外部实体 n1 注册用户   : 60,120,120,60   (左上)
          外部实体 n2 匿名访客   : 60,560,120,60   (左下)
          外部实体 n3 管理员     : 990,120,120,60  (右上)
          外部实体 n4 AI审核服务 : 980,560,140,60  (右下)
          中央加工 n5 P0         : 455,350,260,90  (中心 585,395)
          数据存储 y=720,h=40,w=140,步距160：
            n6  D1 草稿库 : 114,720
            n7  D2 笔记库 : 274,720
            n8  D3 互动库 : 434,720
            n9  D4 评论库 : 594,720
            n10 D5 治理库 : 754,720
            n11 D6 成长库 : 914,720
        -->
        <!-- 外部实体 -->
        <mxCell id="n1" value="注册用户" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n2" value="匿名访客" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;fontSize=14;" vertex="1" parent="1">
