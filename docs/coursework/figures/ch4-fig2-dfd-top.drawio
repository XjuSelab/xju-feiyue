        </mxCell>
        <mxCell id="n4" value="AI 审核服务" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="560" width="140" height="60" as="geometry"/>
