<mxfile host="app.diagrams.net" modified="2026-07-06T11:10:00.000Z" agent="draw.io" version="21.0.0">
  <diagram name="举报-AI审查-裁决-顺序图" id="seq-report">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" pageWidth="1200" pageHeight="850">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="t" value="图6-3　举报—AI审查—人工裁决顺序图" style="text;html=1;align=center;fontSize=14;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="300" y="10" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- Lifelines: 用户, 前端, 后端, AI, 管理员, DB -->
        <mxCell id="ll-u" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="80" y="60"/><mxPoint x="80" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-u" value="用户" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;fontSize=11;" parent="1" vertex="1"><mxGeometry x="45" y="50" width="70" height="35"/></mxCell>

        <mxCell id="ll-fe" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="220" y="60"/><mxPoint x="220" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-fe" value="前端" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=11;" parent="1" vertex="1"><mxGeometry x="190" y="50" width="60" height="35"/></mxCell>

        <mxCell id="ll-be" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="60"/><mxPoint x="370" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-be" value="后端FastAPI" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=11;" parent="1" vertex="1"><mxGeometry x="335" y="50" width="70" height="35"/></mxCell>

        <mxCell id="ll-ai" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="550" y="60"/><mxPoint x="550" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-ai" value="AI服务" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=11;" parent="1" vertex="1"><mxGeometry x="515" y="50" width="70" height="35"/></mxCell>

        <mxCell id="ll-admin" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="740" y="60"/><mxPoint x="740" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-admin" value="管理员" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=11;" parent="1" vertex="1"><mxGeometry x="705" y="50" width="70" height="35"/></mxCell>

        <mxCell id="ll-db" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="910" y="60"/><mxPoint x="910" y="800"/></mxGeometry></mxCell>
        <mxCell id="hd-db" value="数据库" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=11;" parent="1" vertex="1"><mxGeometry x="880" y="50" width="60" height="35"/></mxCell>

        <!-- 1. 举报 -->
        <mxCell id="m1" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="80" y="105"/><mxPoint x="216" y="105"/></mxGeometry></mxCell>
        <mxCell id="m1t" value="1. 点击「举报」" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="110" y="95" width="80" height="15"/></mxCell>

        <!-- 2. 选择类型 -->
        <mxCell id="m2" style="endArrow=open;html=1;endFill=0;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="216" y="130"/><mxPoint x="84" y="130"/></mxGeometry></mxCell>
        <mxCell id="m2t" value="2. 弹出举报面板(8类型)" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="95" y="120" width="120" height="15"/></mxCell>

        <!-- 3. submit -->
        <mxCell id="m3" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="80" y="160"/><mxPoint x="216" y="160"/></mxGeometry></mxCell>
        <mxCell id="m3t" value="3. 选择类型并提交" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="105" y="150" width="90" height="15"/></mxCell>

        <!-- 4. POST /reports -->
        <mxCell id="m4" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="220" y="185"/><mxPoint x="366" y="185"/></mxGeometry></mxCell>
        <mxCell id="m4t" value="4. POST /reports" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="250" y="175" width="90" height="15"/></mxCell>

        <!-- 5. 创建工单 -->
        <mxCell id="m5" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="210"/><mxPoint x="906" y="210"/></mxGeometry></mxCell>
        <mxCell id="m5t" value="5. INSERT reports(含target_snapshot)" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="520" y="200" width="180" height="15"/></mxCell>

        <!-- 6. 受理回执 -->
        <mxCell id="m6" style="endArrow=open;html=1;endFill=0;strokeWidth=1;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="366" y="240"/><mxPoint x="224" y="240"/></mxGeometry></mxCell>
        <mxCell id="m6t" value="6. 「举报已受理」" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="255" y="230" width="80" height="15"/></mxCell>

        <!-- 7. 异步AI审查 -->
        <mxCell id="m7" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="275"/><mxPoint x="546" y="275"/></mxGeometry></mxCell>
        <mxCell id="m7t" value="7. [异步] 送AI审查" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="400" y="265" width="90" height="15"/></mxCell>

        <!-- 8. AI返回 -->
        <mxCell id="m8" style="endArrow=open;html=1;endFill=0;strokeWidth=1;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="546" y="305"/><mxPoint x="374" y="305"/></mxGeometry></mxCell>
        <mxCell id="m8t" value="8. {label, confidence, reason}" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="400" y="295" width="140" height="15"/></mxCell>

        <!-- alt 高置信 -->
        <mxCell id="alt-box" value="" style="rounded=0;html=1;fillColor=none;strokeColor=#999;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="360" y="320" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="alt-l" value="alt" style="text;html=1;fontSize=10;fontColor=#999;" parent="1" vertex="1"><mxGeometry x="365" y="320" width="20" height="15"/></mxCell>
        <mxCell id="alt-txt" value="[conf≥0.9违规]&#xa;自动隐藏目标内容" style="text;html=1;fontSize=8;fontColor=#cc0000;" parent="1" vertex="1"><mxGeometry x="410" y="330" width="100" height="25"/></mxCell>

        <!-- 9. AI高置信 → 隐藏 -->
        <mxCell id="m9" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="340"/><mxPoint x="906" y="340"/></mxGeometry></mxCell>
        <mxCell id="m9t" value="9. UPDATE note/comment SET status='pending'" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="480" y="330" width="220" height="15"/></mxCell>

        <!-- 10. 管理员打开队列 -->
        <mxCell id="m10" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="740" y="410"/><mxPoint x="374" y="410"/></mxGeometry></mxCell>
        <mxCell id="m10t" value="10. GET /admin/reports" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="480" y="400" width="140" height="15"/></mxCell>

        <!-- 11. 返回工单 -->
        <mxCell id="m11" style="endArrow=open;html=1;endFill=0;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="374" y="440"/><mxPoint x="736" y="440"/></mxGeometry></mxCell>
        <mxCell id="m11t" value="11. 工单列表(含AI结论+快照)" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="480" y="430" width="160" height="15"/></mxCell>

        <!-- 12. 裁决 -->
        <mxCell id="m12" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="740" y="475"/><mxPoint x="374" y="475"/></mxGeometry></mxCell>
        <mxCell id="m12t" value="12. POST /reports/{id}/resolve" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="480" y="465" width="170" height="15"/></mxCell>

        <!-- alt 裁决分支 -->
        <mxCell id="alt2" value="" style="rounded=0;html=1;fillColor=none;strokeColor=#999;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="360" y="495" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="alt2-l" value="alt" style="text;html=1;fontSize=10;fontColor=#999;" parent="1" vertex="1"><mxGeometry x="365" y="495" width="20" height="15"/></mxCell>
        <mxCell id="alt2-txt" value="[delete] 级联删除内容&#xa;[dismiss] 恢复展示" style="text;html=1;fontSize=8;" parent="1" vertex="1"><mxGeometry x="400" y="500" width="130" height="25"/></mxCell>

        <!-- 13. 更新DB -->
        <mxCell id="m13" style="endArrow=block;html=1;endFill=1;strokeWidth=1;fontSize=9;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="510"/><mxPoint x="906" y="510"/></mxGeometry></mxCell>
        <mxCell id="m13t" value="13. UPDATE report status | DELETE/UPDATE content" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="480" y="500" width="230" height="15"/></mxCell>

        <!-- 14. 返回结果 -->
        <mxCell id="m14" style="endArrow=open;html=1;endFill=0;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="374" y="545"/><mxPoint x="736" y="545"/></mxGeometry></mxCell>
        <mxCell id="m14t" value="14. 裁决完成" style="text;html=1;fontSize=9;" parent="1" vertex="1"><mxGeometry x="520" y="536" width="60" height="15"/></mxCell>

        <!-- AI不可用分支 -->
        <mxCell id="ai-fail" value="[AI不可用] 工单直入人工队列,&#xa;举报受理不受影响" style="text;html=1;fontSize=8;fontColor=#cc6600;fontStyle=2;" parent="1" vertex="1"><mxGeometry x="370" y="580" width="180" height="30"/></mxCell>
        <mxCell id="ai-fail-arrow" style="endArrow=open;html=1;endFill=0;fontSize=9;dashed=1;" parent="1" edge="1"><mxGeometry><mxPoint x="370" y="600"/><mxPoint x="740" y="600"/></mxGeometry></mxCell>
        <mxCell id="ai-fail-t" value="旁路→人工队列" style="text;html=1;fontSize=8;fontColor=#cc6600;" parent="1" vertex="1"><mxGeometry x="480" y="592" width="80" height="12"/></mxCell>
      </root>
    </mxGraphModel>
