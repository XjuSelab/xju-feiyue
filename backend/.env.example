# Copy to .env.local and fill in real values.

# Default to sqlite for zero-setup local dev. For production, switch to:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/labnotes
DATABASE_URL=sqlite+aiosqlite:///./labnotes.db

# JWT signing — generate with `openssl rand -hex 32`
JWT_SECRET=change-me-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=10080

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# CORS — comma-separated list of allowed origins. Include both
# localhost and 127.0.0.1 because browsers treat them as different
# origins for CORS purposes.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# When set, /ai/compose will skip the upstream call and echo input verbatim.
# Useful for tests and offline dev.
DEEPSEEK_DRY_RUN=0
